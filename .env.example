# Server
PORT=3000
NODE_ENV=development # or "production"

# Session secret (generate with `openssl rand -base64 32`)
SESSION_SECRET=changeme

# WebAuthn (RP_ID is your domain without protocol+port, ORIGIN includes protocol+port)
RP_ID=localhost
ORIGIN=http://localhost:3000

# MongoDB (optional, default uses file system storage)
USE_MONGO=false # or "true"
MONGO_URI=mongodb://localhost:27017/funwithflags

# Auto-cleanup of inactive instances (in milliseconds)
INSTANCE_MAX_AGE_MS=86400000 # 24 hours
CLEANUP_INTERVAL_MS=3600000 # 1 hour
