{% extends "layouts/base.njk" %}

{% block content %}
<div class="row justify-content-center">
  <div class="col-md-8 col-lg-7">
    <!-- Auth Verifier Selector Card -->
    <div class="card shadow mb-4">
      <div class="card-header bg-secondary text-white">
        <i class="bi bi-shield-check"></i> Authentication Verifier
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3 mb-md-0">
            <label class="form-label small text-muted">Demo Verifiers</label>
            <select class="form-select form-select-sm" id="auth-verifier-select-demo">
              <option value=""></option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label small text-muted">Security Verifiers</label>
            <select class="form-select form-select-sm" id="auth-verifier-select-security">
              <option value=""></option>
            </select>
          </div>
        </div>
        <div class="mt-3 p-2 bg-light rounded small">
          <strong id="current-verifier-name">{{ authVerifier.name }}</strong>
          <span class="text-muted ms-2">(#{{ authVerifier.id }})</span>
          {% if authVerifier.rewardFlagId %}
          <span class="badge bg-warning text-dark ms-2"><i class="bi bi-trophy-fill"></i></span>
          {% endif %}
          <p class="mb-0 mt-1 text-muted" id="current-verifier-desc">{{ authVerifier.description }}</p>
        </div>
      </div>
    </div>

    <!-- Login Card -->
    <div class="card shadow">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="bi bi-box-arrow-in-right"></i> Login</h4>
      </div>
      <div class="card-body">

        {% if error %}
        <div class="alert alert-danger">
          <i class="bi bi-exclamation-triangle"></i> {{ error }}
        </div>
        {% endif %}

        <!-- Password Login Form -->
        {% if authVerifier.ui.showPasswordForm %}
        <form action="/login" method="POST" id="login-form">
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" class="form-control" id="username" name="username"
                   {% if authVerifier.options.conditionalUI %}autocomplete="username webauthn"{% else %}autocomplete="username"{% endif %}
                   required>
          </div>
          <div class="mb-3" id="password-field">
            <label for="password" class="form-label">Password</label>
            <input type="password" class="form-control" id="password" name="password" autocomplete="current-password" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right"></i> Login
          </button>
        </form>
        {% endif %}

        <!-- Username-only form for non-discoverable flow -->
        {% if authVerifier.ui.showUsernameFirst %}
        <form id="username-check-form">
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" class="form-control" id="username" name="username" autocomplete="username" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-arrow-right"></i> Continue
          </button>
        </form>
        <form action="/login" method="POST" id="password-form" style="display: none;">
          <input type="hidden" id="hidden-username" name="username">
          <div class="mb-3">
            <label for="password" class="form-label">Password for <strong id="username-display"></strong></label>
            <input type="password" class="form-control" id="password" name="password" autocomplete="current-password" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right"></i> Login
          </button>
          <button type="button" class="btn btn-link w-100" id="back-btn">Back</button>
        </form>
        {% endif %}

        <!-- Passkey button for discoverable flow -->
        {% if authVerifier.ui.showPasskeyButton %}
        <div class="mt-3">
          <div class="text-center text-muted mb-2">or</div>
          <button type="button" class="btn btn-outline-primary w-100" id="passkey-login-btn">
            <i class="bi bi-key"></i> Login with Passkey
          </button>
        </div>
        {% endif %}

        <!-- Passkey status area -->
        <div id="passkey-status" class="mt-3" style="display: none;">
          <div class="alert" id="passkey-alert">
            <span id="passkey-message"></span>
          </div>
        </div>

        <!-- Flag display area -->
        <div id="flag-display" class="mt-3" style="display: none;">
          <div class="alert alert-success">
            <h5><i class="bi bi-trophy"></i> Reward Flag Unlocked!</h5>
            <code id="captured-flag"></code>
            <p class="mb-0 mt-2 small" id="flag-message"></p>
          </div>
        </div>
      </div>
      <div class="card-footer text-center">
        <span class="text-muted">Don't have an account?</span>
        <a href="/register">Register here</a>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
{% include "partials/passkey-scripts.njk" %}
<script>
document.addEventListener('DOMContentLoaded', async function() {
  const authVerifier = {{ authVerifier | dump | safe }};

  // Load auth verifiers for selector
  await loadAuthVerifiers();

  // Discoverable passkey login
  const passkeyLoginBtn = document.getElementById('passkey-login-btn');
  if (passkeyLoginBtn) {
    passkeyLoginBtn.addEventListener('click', async function() {
      await passkeyAuthenticate({ discoverable: true });
    });
  }

  // Conditional UI
  {% if authVerifier.options.conditionalUI %}
  if (window.PublicKeyCredential &&
      typeof PublicKeyCredential.isConditionalMediationAvailable === 'function') {
    PublicKeyCredential.isConditionalMediationAvailable().then(available => {
      if (available) {
        passkeyAuthenticate({ conditionalUI: true });
      }
    });
  }
  {% endif %}

  // Username check form for non-discoverable flow
  const usernameCheckForm = document.getElementById('username-check-form');
  if (usernameCheckForm) {
    usernameCheckForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      const username = document.getElementById('username').value;

      try {
        const response = await fetch('/login/check-username', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username })
        });
        const data = await response.json();

        if (!data.exists) {
          showPasskeyStatus('error', 'User not found');
          return;
        }

        if (data.hasPasskeys) {
          // Trigger passkey authentication
          await passkeyAuthenticate({ username, discoverable: false });
        } else {
          // Show password form
          document.getElementById('username-check-form').style.display = 'none';
          document.getElementById('password-form').style.display = 'block';
          document.getElementById('hidden-username').value = username;
          document.getElementById('username-display').textContent = username;
          document.getElementById('password').focus();
        }
      } catch (error) {
        showPasskeyStatus('error', error.message);
      }
    });

    const backBtn = document.getElementById('back-btn');
    if (backBtn) {
      backBtn.addEventListener('click', function() {
        document.getElementById('password-form').style.display = 'none';
        document.getElementById('username-check-form').style.display = 'block';
      });
    }
  }
});

async function loadAuthVerifiers() {
  try {
    const response = await fetch('/verifiers/api/list?target=authentication');
    const data = await response.json();

    const demoSelect = document.getElementById('auth-verifier-select-demo');
    const securitySelect = document.getElementById('auth-verifier-select-security');

    data.verifiers.forEach(v => {
      const option = document.createElement('option');
      option.value = v.id;
      // Include section number for security verifiers
      option.textContent = v.section ? `${v.name} (§${v.section})` : v.name;
      if (v.id === data.currentAuthVerifier) {
        option.selected = true;
      }

      if (v.type === 'demo') {
        demoSelect.appendChild(option);
      } else if (v.type === 'security') {
        securitySelect.appendChild(option);
      }
    });

    // Add change handlers
    demoSelect.addEventListener('change', function() {
      if (this.value) {
        switchVerifier(parseInt(this.value, 10), 'authentication');
      }
    });

    securitySelect.addEventListener('change', function() {
      if (this.value) {
        switchVerifier(parseInt(this.value, 10), 'authentication');
      }
    });
  } catch (error) {
    console.error('Failed to load verifiers:', error);
  }
}
</script>
{% endblock %}
