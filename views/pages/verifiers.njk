    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Verifier switch buttons
  document.querySelectorAll('.switch-verifier-btn').forEach(btn => {
    btn.addEventListener('click', async function() {
      const verifierId = this.dataset.verifierId;
      const target = this.dataset.target;
      await switchVerifier(verifierId, target);
    });
  });

  // Hint reveal on click
  document.querySelectorAll('.hint-cell').forEach(cell => {
    cell.addEventListener('click', function() {
      const hintText = this.querySelector('.hint-text');
      if (hintText) {
        hintText.classList.toggle('revealed');
      }
    });
  });
});
</script>
{% endblock %}
